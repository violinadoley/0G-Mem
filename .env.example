# 0G Mem — environment variables
# Copy to .env and fill in your values. Never commit .env.

# ─── Wallet (required) ────────────────────────────────────────────────────────
AGENT_KEY=0x_your_private_key_here
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# ─── Deployed contracts (filled after running: make deploy) ───────────────────
MEMORY_REGISTRY_ADDRESS=
MEMORY_NFT_ADDRESS=

# ─── 0G DA node (for docker-compose) ─────────────────────────────────────────
# Used by envfile.env — the DA Docker node reads these directly
COMBINED_SERVER_CHAIN_RPC=https://evmrpc-testnet.0g.ai
COMBINED_SERVER_PRIVATE_KEY=your_private_key_without_0x_prefix

# ─── 0G Compute (inference) ───────────────────────────────────────────────────
# Get these after setting up a ledger account on 0G Compute testnet:
#   1. zerog-compute-cli ledger create --amount 3
#   2. zerog-compute-cli inference acknowledge-provider --provider <PROVIDER>
#   3. zerog-compute-cli inference transfer --provider <PROVIDER> --amount 1
#   4. zerog-compute-cli inference get-secret --provider <PROVIDER>  → copy app-sk-*
ZEROG_SERVICE_URL=https://<provider>.0g.ai
ZEROG_API_KEY=app-sk-your_secret_here
ZEROG_MODEL=Qwen/Qwen2.5-7B-Instruct

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Get from @BotFather: /newbot → copy the token
TELEGRAM_BOT_TOKEN=your_token_here

# ─── Optional ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
